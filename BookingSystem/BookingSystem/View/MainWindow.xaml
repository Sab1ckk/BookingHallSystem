<Window x:Class="BookingSystem.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:BookingSystem"
        mc:Ignorable="d"
        Title="Restaurant Admin Panel" Height="800" Width="1400"
        WindowStartupLocation="CenterScreen"
        Background="#F5F7FA">

    <Window.Resources>
        <SolidColorBrush x:Key="SidebarBackground" Color="#1E293B"/>
        <SolidColorBrush x:Key="AccentColor" Color="#FFFD7F67"/>
        <SolidColorBrush x:Key="TextLight" Color="#F8FAFC"/>
        <SolidColorBrush x:Key="TextDark" Color="#334155"/>
        <SolidColorBrush x:Key="HoverColor" Color="#334155"/>

        <Style x:Key="SideBarButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource TextLight}"/>
            <Setter Property="FontFamily" Value="Segoe UI Semibold"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="Height" Value="45"/>
            <Setter Property="Margin" Value="10,5,10,5"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Padding" Value="15,0,0,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" 
                                Background="{TemplateBinding Background}"
                                CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Left" 
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{StaticResource HoverColor}"/>
                                <Setter Property="Foreground" Value="{StaticResource AccentColor}"/>
                                <Setter Property="Cursor" Value="Hand"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#0F172A"/>
                                <Setter Property="RenderTransform">
                                    <Setter.Value>
                                        <ScaleTransform ScaleX="0.98" ScaleY="0.98"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="HeaderMenuItem" TargetType="MenuItem">
            <Setter Property="Foreground" Value="{StaticResource TextDark}"/>
            <Setter Property="FontFamily" Value="Segoe UI Semibold"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Padding" Value="15,10"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="260"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="{StaticResource SidebarBackground}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="100"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" VerticalAlignment="Center" HorizontalAlignment="Center" Orientation="Horizontal">
                    <Image Source="/Resourse/Image/logotip.png" Width="50" Margin="0,0,10,0"/>
                    <StackPanel>
                        <TextBlock Text="RESTAURANT" Foreground="White" FontSize="22" FontWeight="Bold" />
                        <TextBlock Text="Management System" Foreground="{StaticResource AccentColor}" FontSize="12" HorizontalAlignment="Center"/>
                    </StackPanel>
                </StackPanel>
                

                <StackPanel Grid.Row="1" Margin="0,20,0,0">
                    <Button Content="🏠  Главная" Command="{Binding OpenHomeCommand}" Style="{StaticResource SideBarButton}"/>
                    <Button Content="📅  Бронирования" Command="{Binding OpenReservationCommand}" Style="{StaticResource SideBarButton}"/>
                    <Button Content="🎭  Мероприятия" Command="{Binding OpenEventsCommand}" Style="{StaticResource SideBarButton}"/>
                    <Button Content="📊  Отчеты" Command="{Binding OpenReportCommand}" Style="{StaticResource SideBarButton}"/>

                    <Separator Background="#334155" Margin="20,10" Opacity="0.5"/>

                    <Button Content="⚙️  База данных " Command="{Binding OpenHomeCommand}" Style="{StaticResource SideBarButton}" IsEnabled="False" Margin="10,-5"/>
                    <Button Content="▦  Типы мероприятий" Command="{Binding OpenUsersCommand}" Style="{StaticResource SideBarButton}" Margin="10,-5"/>
                    <Button Content="▦  Залы" Command="{Binding OpenUsersCommand}" Style="{StaticResource SideBarButton}" Margin="10,-5"/>
                    <Button Content="▦  Пользователи" Command="{Binding OpenUsersCommand}" Style="{StaticResource SideBarButton}" Margin="10,-5"/>
                    <Button Content="▦  Сотрудники" Command="{Binding OpenUsersCommand}" Style="{StaticResource SideBarButton}" Margin="10,-5"/>
                    <Button Content="▦  Должности" Command="{Binding OpenUsersCommand}" Style="{StaticResource SideBarButton}" Margin="10,-5"/>
                </StackPanel>

                <TextBlock Grid.Row="2" Text="v alpha" Foreground="#475569" Margin="20" HorizontalAlignment="Center"/>
            </Grid>
        </Border>

        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="60"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="White">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="15" Direction="270" ShadowDepth="1" Opacity="0.1"/>
                </Border.Effect>
                <Grid Margin="20,0">
                    <TextBlock Text="Панель управления" VerticalAlignment="Center" FontSize="18" Foreground="{StaticResource TextDark}" FontWeight="Medium"/>

                    <Menu Background="Transparent" HorizontalAlignment="Right" VerticalAlignment="Center">
                        <MenuItem Header="Выйти" Command="{Binding LogoutCommand}" Style="{StaticResource HeaderMenuItem}" Foreground="#E11D48"/>
                    </Menu>
                </Grid>
            </Border>

            <Frame Grid.Row="1" 
                   Content="{Binding CurrentPage}" 
                   NavigationUIVisibility="Hidden" 
                   Margin="25"/>
        </Grid>
    </Grid>
</Window>