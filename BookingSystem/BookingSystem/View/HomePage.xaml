<Page x:Class="BookingSystem.View.HomePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:BookingSystem.View"
      mc:Ignorable="d" 
      d:DesignHeight="720" d:DesignWidth="1100"
      Title="HomePage">

    <Page.Resources>
        <!-- Стиль для карточек -->
        <Style x:Key="DashboardCard" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="15"/>
            <Setter Property="Padding" Value="20"/>
            <Setter Property="Margin" Value="10"/>
        </Style>

        <Style x:Key="RoomListItem" TargetType="ListBoxItem">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="RoomBorder" 
                                Background="#F8FAFC" 
                                CornerRadius="10" 
                                Margin="0,0,0,8" 
                                Padding="15,12">
                            <ContentPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="RoomBorder" Property="Background" Value="#EDF2F7"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Page.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="10,0,10,25">
            <TextBlock Text="Обзор ресторана" FontSize="28" FontWeight="Bold" Foreground="#1E293B"/>
            <TextBlock Text="Актуальное состояние залов и статистика на сегодня" Foreground="#64748B" FontSize="14"/>
        </StackPanel>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <!-- Список залов -->
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource DashboardCard}">
                <DockPanel>
                    <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,20">
                        <Ellipse Width="12" Height="12" Fill="#10B981" Margin="0,0,10,0"/>
                        <TextBlock Text="Доступные залы" FontSize="18" FontWeight="SemiBold" Foreground="#1E293B"/>
                    </StackPanel>

                    <ListBox ItemsSource="{Binding FreeRooms}" 
                             Background="Transparent" 
                             BorderThickness="0" 
                             ItemContainerStyle="{StaticResource RoomListItem}"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid d:DesignWidth="400">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <Border Width="40" Height="40" Background="#E2E8F0" CornerRadius="8" Grid.Column="0">
                                        <TextBlock Text="🏠" VerticalAlignment="Center" HorizontalAlignment="Center" FontSize="18"/>
                                    </Border>

                                    <StackPanel Grid.Column="1" Margin="15,0">
                                        <TextBlock Text="{Binding Name}" FontSize="16" FontWeight="Bold" Foreground="#334155"/>
                                        <TextBlock Text="Готов к приему гостей" FontSize="12" Foreground="#94A3B8"/>
                                    </StackPanel>

                                    <Border Grid.Column="2" Background="#DBEAFE" Padding="10,4" CornerRadius="12" VerticalAlignment="Center">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="вместимость: " FontSize="11" Foreground="#1E40AF"/>
                                            <TextBlock Text="{Binding Capacity}" FontSize="11" FontWeight="Bold" Foreground="#1E40AF"/>
                                        </StackPanel>
                                    </Border>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </DockPanel>
            </Border>

            <StackPanel Grid.Column="1">
                <Border Style="{StaticResource DashboardCard}" Background="#1E293B">
                    <StackPanel>
                        <TextBlock Text="Лидер бронирований" Foreground="#94A3B8" FontSize="13" FontWeight="Medium"/>
                        <TextBlock Text="{Binding MostPopularRoom}" 
                                   FontSize="24" 
                                   Foreground="White" 
                                   FontWeight="Bold" 
                                   Margin="0,10"
                                   TextWrapping="Wrap"/>
                        <Border Background="#FFFD7F67" HorizontalAlignment="Left" Padding="8,4" CornerRadius="6">
                            <TextBlock Text="ТОП МЕСЯЦА" FontSize="10" FontWeight="Bold" Foreground="White"/>
                        </Border>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource DashboardCard}">
                    <StackPanel>
                        <TextBlock Text="Быстрые действия" FontSize="16" FontWeight="SemiBold" Foreground="#1E293B" Margin="0,0,0,15"/>
                        <Button Content="+ Новое бронирование" 
                                Background="#F1F5F9" 
                                Foreground="#1E293B" 
                                BorderThickness="0" 
                                Padding="10" 
                                Margin="0,0,0,10"
                                Cursor="Hand">
                            <Button.Resources>
                                <Style TargetType="Border">
                                    <Setter Property="CornerRadius" Value="8"/>
                                </Style>
                            </Button.Resources>
                        </Button>
                        <TextBlock Text="Всего залов в системе: 12" FontSize="12" Foreground="#64748B" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Grid>
    </Grid>
</Page>